{
  "name": "agent-trigger-kit",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "Cross-agent trigger layer toolkit for Codex, Claude Code, and Cursor.",
  "license": "MIT",
  "bin": {
    "agent-trigger-kit": "scripts/cli.mjs"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "node --test",
    "preflight": "npm run lint && npm run format:check && npm test && npm run validate && npm run check:scratch-namespace",
    "check:scratch-namespace": "node scripts/check-scratch-namespace.mjs",
    "ops:plugin-cache-sync": "node scripts/sync-codex-plugin-cache.mjs",
    "ops:local-agent-sync": "node scripts/update-local-agent-triggers.mjs",
    "ops:plugin-version-check": "node scripts/check-plugin-version.mjs",
    "ops:backfill-outcomes": "node scripts/backfill-historical-outcomes.mjs",
    "ops:premerge-version-check": "node scripts/premerge-version-check.mjs",
    "validate": "node scripts/validate-trigger-layer.mjs --root ."
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
